{
  "name": "ft-transcendence",
  "private": true,
  "version": "1.0.0",
  "description": "ft_transcendence monorepo",
  "scripts": {
    "dev": "docker compose up -d db && POSTGRES_ADDRESS=localhost SERVICE_URL_NEXTJS=http://localhost:3000 NEXT_PUBLIC_GAMESERVER_URL=http://localhost:4000 pnpm --parallel --stream run dev",
    "start": "pnpm --parallel --stream run start",
    "build": "pnpm --recursive run build",
    "lint": "pnpm eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter tests run test",
    "test:mobile": "pnpm --filter tests run test:mobile",
    "test:all": "pnpm --filter tests run test:all",
    "test:ui": "pnpm --filter tests run test:ui"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "3.7.4",
    "typescript-eslint": "^8.57.2"
  }
}
