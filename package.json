{
  "name": "ft-transcendence",
  "private": true,
  "version": "1.0.0",
  "description": "ft_transcendence monorepo",
  "scripts": {
    "dev": "pnpm --parallel --stream run dev",
    "start": "pnpm --parallel --stream run start",
    "build": "pnpm --recursive run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "3.7.4",
    "typescript-eslint": "^8.48.1"
  }
}
