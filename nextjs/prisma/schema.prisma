// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  username         String   @unique
  passwordHash     String
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  xp               Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Forty two creds
  fortyTwoId       String?  @unique
  fortyTwoEmail    String?
  fortyTwoLogin    String?

  // Chess Stats
  wins             Int      @default(0)
  losses           Int      @default(0)
  draws            Int      @default(0)

  // Two player chess
  gamesAsWhite     Game[]   @relation("WhitePlayer")
  gamesAsBlack     Game[]   @relation("BlackPlayer")

  // Four player chess
  gamesAsBlue      GameFour[]   @relation("BluePlayer")
  gamesAsYellow    GameFour[]   @relation("YellowPlayer")
  gamesAsRed       GameFour[]   @relation("RedPlayer")
  gamesAsGreen     GameFour[]   @relation("GreenPlayer")

  // Connect Stats
  connectWins      Int      @default(0)
  connectLosses    Int      @default(0)
  connectDraws     Int      @default(0)

  connectgameAsRed        connectGame[]  @relation("connectRedPlayer")
  connectgameAsYellow     connectGame[]  @relation("connectYellowPlayer")
}

model Game {
  id            Int       @id @default(autoincrement())

  whitePlayerId Int
  blackPlayerId Int

  whitePlayer   User      @relation("WhitePlayer", fields: [whitePlayerId], references: [id])
  blackPlayer   User     @relation("BlackPlayer", fields: [blackPlayerId], references: [id])
  
  winner        String?
  reason        String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  finishedAt    DateTime?
}

model GameFour {
  id            Int       @id @default(autoincrement())

  bluePlayerId Int
  greenPlayerId Int
  yellowPlayerId Int
  redPlayerId Int

  bluePlayer   User      @relation("BluePlayer", fields: [bluePlayerId], references: [id])
  yellowPlayer   User     @relation("YellowPlayer", fields: [yellowPlayerId], references: [id])
  redPlayer   User      @relation("RedPlayer", fields: [redPlayerId], references: [id])
  greenPlayer   User      @relation("GreenPlayer", fields: [greenPlayerId], references: [id])

  winner        String?
  reason        String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  finishedAt    DateTime?
}

model connectGame {
  id           Int         @id @default(autoincrement())

  connectRedPlayerId     Int
  connectYellowPlayerId  Int

  connectRedPlayer          User    @relation("connectRedPlayer", fields: [connectRedPlayerId], references: [id])
  connectYellowPlayer       User    @relation("connectYellowPlayer", fields: [connectYellowPlayerId], references: [id])

  winner        String?
  reason        String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  finishedAt    DateTime?
}