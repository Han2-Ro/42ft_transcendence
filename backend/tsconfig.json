{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
	"incremental": true, 
    "forceConsistentCasingInFileNames": true,
	"declaration": true,
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}